{
  "name": "typing-student",
  "version": "1.0.1",
  "description": "Typing Student Desktop Application",
  "main": "main.js",
  "author": "Kuldeep",
  "license": "ISC",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.kuldeep.typingstudent",
    "productName": "Typing Student",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "package.json",
      "assets/**/*",
      "afterPack.js"
    ],
    "extraResources": [
      {
        "from": "../student/dist",
        "to": "student/dist"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/TypingPortal.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}